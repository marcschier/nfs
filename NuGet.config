<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Isolate the repository from any machine-global feeds so restore is deterministic
       (and Central Package Management does not trip over multiple unmapped sources). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
