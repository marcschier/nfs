# Normalize all text files to LF on checkin and checkout.
* text=auto eol=lf

*.cs      text eol=lf
*.csproj  text eol=lf
*.props   text eol=lf
*.targets text eol=lf
*.slnx    text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.x       text eol=lf
*.sh      text eol=lf

# Binary assets.
*.png  binary
*.ico  binary
*.pfx  binary
*.snk  binary
