<Project>

  <!-- Common settings for every project in the repository. -->
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Features>strict</Features>
    <Deterministic>true</Deterministic>
    <InvariantGlobalization>true</InvariantGlobalization>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <AnalysisLevel>latest-recommended</AnalysisLevel>
    <!-- Style violations are surfaced by the IDE and `dotnet format`, not the build,
         so day-to-day builds stay fast. Correctness/AOT warnings are still errors. -->
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
    <AccelerateBuildsInVisualStudio>true</AccelerateBuildsInVisualStudio>
  </PropertyGroup>

  <!-- Strong-name signing. Every assembly is full-signed with the committed key so the
       shipped packages carry a stable identity. Strong naming is an identity, not a secret,
       so the key is checked in (standard practice for OSS .NET libraries) and CI signs on
       both Windows and Linux. NfsPublicKey is the key's full public key, used to grant
       InternalsVisibleTo to the (also-signed) test assemblies. Public key token:
       a5b998207a9d983e. -->
  <PropertyGroup>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>$(MSBuildThisFileDirectory)nfs.snk</AssemblyOriginatorKeyFile>
    <NfsPublicKey></NfsPublicKey>
  </PropertyGroup>

  <!-- Repository / package metadata (used only when packing). -->
  <PropertyGroup>
    <Product>Nfs</Product>
    <Authors>marcschier</Authors>
    <RepositoryUrl>https://github.com/marcschier/nfs</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/marcschier/nfs</PackageProjectUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <!-- Analyzers and versioning applied everywhere. -->
  <ItemGroup>
    <PackageReference Include="Nerdbank.GitVersioning" PrivateAssets="all" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="all" />
    <PackageReference Include="Roslynator.Formatting.Analyzers" PrivateAssets="all" />
  </ItemGroup>

</Project>
